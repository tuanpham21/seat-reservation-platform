# Copy this file to .env for local development.
# Keep real secrets in .env only. Do not commit live Stripe keys or production credentials.

# Matches docker-compose.yml.
DATABASE_URL="postgresql://seats:seats@localhost:5432/seats?schema=public"

# Public base URL for local callbacks and Stripe Checkout redirects.
APP_URL="http://localhost:3000"

# Optional. Leave blank to infer refresh-cookie Secure from APP_URL.
# Set to "true" behind HTTPS or "false" for local HTTP reviewer runs.
AUTH_COOKIE_SECURE=""

# Generate a local value with: openssl rand -base64 32
JWT_SECRET="replace-with-a-random-32-byte-secret"

# Stripe test mode only for local/reviewer runs. Checkout is disabled until
# STRIPE_SECRET_KEY is replaced with a real Stripe test secret key and a usable
# webhook signing secret is configured.
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
# Optional Docker reviewer path: the Stripe CLI sidecar writes the generated
# webhook signing secret here and the app reads it per webhook request.
STRIPE_WEBHOOK_SECRET_FILE=""

# Seat hold duration before an unpaid hold can be released.
SEAT_HOLD_TTL_SECONDS="600"

# Session lifetimes.
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_SESSION_TTL_DAYS="90"
