{
  "name": "seat-reservation-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "package:submission": "node scripts/create-submission-zip.mjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "argon2": "0.40.3",
    "jose": "5.9.6",
    "lucide-react": "0.468.0",
    "next": "14.2.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "17.5.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.23",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
